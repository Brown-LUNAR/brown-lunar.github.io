@article{Spatiallanguageunderstandingforobjectsea,
  title = {Spatial language understanding for object search in partially observed city-scale environments},
  pub_year = {2021},
  citation = {2021 30th IEEE International Conference on Robot & Human Interactive …, 2021},
  author = {Kaiyu Zheng and Deniz Bayazit and Rebecca Mathew and Ellie Pavlick and Stefanie Tellex},
  pub_date = {2021/8/8},
